# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# LLM Provider: ollama or dashscope
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# DashScope (Alibaba Cloud / 百炼)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.5-plus
# 分环节模型分配（V1.1优化）
# DASHSCOPE_MODEL_ANALYZE=qwen-turbo       # Step 2 分析分类（轻量）
# DASHSCOPE_MODEL_COMPILE=qwen3.5-plus     # Step 3b 页面编写（质量关键）
# DASHSCOPE_MODEL_REASONING=qwen3.5-plus   # Step 3c 隐式推理（P0升级）
# DASHSCOPE_MODEL_QUERY=qwen3.5-plus       # Query 回答生成

# Feishu App
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Knowledge API
KNOWLEDGE_API_TOKEN=dev-token

# --------------------------------------------------------------------------
# V2.1: Social Media Content Fetcher (ECS Playwright)
# --------------------------------------------------------------------------

# 小红书Cookie — 从浏览器DevTools → Application → Cookies 导出
# 格式: a1=xxx; web_session=xxx; webId=xxx; ...
# 必需字段: a1, web_session
SOCIAL_XHS_COOKIE=

# 微博Cookie — 从浏览器DevTools → Application → Cookies 导出
# 格式: SUB=xxx; SUBP=xxx; ...
SOCIAL_WEIBO_COOKIE=

# 抓取超时（秒），默认60
SOCIAL_FETCH_TIMEOUT=60

# OCR: PaddleOCR免费本地OCR（推荐启用）
SOCIAL_OCR_PADDLE_ENABLED=true

# OCR兜底: DashScope qwen-vl-max（可选，PaddleOCR失败时降级使用）
# 留空则仅用PaddleOCR
SOCIAL_OCR_DASHSCOPE_KEY=
