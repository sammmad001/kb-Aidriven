# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# LLM Provider: ollama or dashscope
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# DashScope (Alibaba Cloud)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Feishu App
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Knowledge API
KNOWLEDGE_API_TOKEN=dev-token
