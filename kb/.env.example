# =====================================================================
# 知识库系统 .env 配置模板
# 复制此文件为 .env 并填入实际值
# =====================================================================

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- LLM ---
LLM_PROVIDER=dashscope

# Ollama (local, used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# DashScope (Alibaba Cloud / 百炼)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.5-plus

# DashScope 分环节模型分配
DASHSCOPE_MODEL_ANALYZE=qwen-turbo
DASHSCOPE_MODEL_COMPILE=qwen3.5-plus
DASHSCOPE_MODEL_REASONING=qwen3.5-plus
DASHSCOPE_MODEL_QUERY=qwen3.5-plus

# --- ASR 语音识别 ---
ASR_ENABLED=true
ASR_MODEL=paraformer-realtime-v2

# --- Feishu ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_USE_WS=false

# --- Knowledge API ---
KNOWLEDGE_API_TOKEN=

# --- Multi-User Auth ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
USER_DB_PATH=data/users.db
DEFAULT_USER_ID=default

# --- Server ---
HOST=0.0.0.0
PORT=8080
CORS_ORIGINS=*

# --- Social Media ---
SOCIAL_XHS_COOKIE=
SOCIAL_WEIBO_COOKIE=
SOCIAL_FETCH_TIMEOUT=60
SOCIAL_OCR_PADDLE_ENABLED=true
SOCIAL_OCR_DASHSCOPE_KEY=

# --- MiroMind Deep Research ---
MIROMIND_API_BASE=https://api.miromind.ai/v1
MIROMIND_API_KEY=
MIROMIND_DEFAULT_MODEL=mirothinker-1-7-deepresearch
MIROMIND_REQUEST_TIMEOUT=300.0
MIROMIND_AUTO_INGEST=true
MIROMIND_MIN_TOKENS=500

# --- Task Scheduling ---
INGEST_CONCURRENCY=3
QUERY_CONCURRENCY=10
LLM_CONCURRENCY=5
TASK_QUEUE_MAX_PER_USER=3
TASK_QUEUE_MAX_SIZE=100
